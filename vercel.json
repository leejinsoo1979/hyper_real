{
  "installCommand": "cd webapp && npm install",
  "buildCommand": "cd webapp && npm run build",
  "outputDirectory": "webapp/dist",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "api/*.js": {
      "memory": 512,
      "maxDuration": 120,
      "includeFiles": "webapp/public/downloads/Lumanova_v1.0.7.rbz"
    }
  }
}
