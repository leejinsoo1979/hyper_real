# Gemini API key (required for real rendering)
VITE_GEMINI_API_KEY=

# Override Gemini model (optional, default: gemini-2.0-flash-exp-image-generation)
# VITE_GEMINI_MODEL=gemini-2.0-flash-exp-image-generation

# Set to "true" to force mock adapters even when API key is present
# VITE_USE_MOCK=true

# Material CDN root. Keep large material assets outside the app bundle.
# Example object paths:
#   thumbs/wood/oak-herringbone-01.webp
#   references/wood/oak-herringbone-01.webp
#   pbr/oak-herringbone-01/basecolor.webp
# VITE_MATERIAL_CDN_BASE=https://cdn.example.com/lumanova/materials
